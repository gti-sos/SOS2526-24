{
  "name": "sos2526-24",
  "version": "0.0.0",
  "description": "- **Team**\r   - Isaac Rodríguez Godino (https://github.com/IsaacRg25)\r   - Elena Bejarano Periñán (https://github.com/elenabejper)\r   - María Jesús Jiménez-Espada Pallarés (https://github.com/mariaajesuus)\r - **Project description**: Our project integrates global datasets on construction costs, household spending on leisure and culture, and average monthly wages. We analyze the economic impact of rising construction prices between 2020/21 and 2024, exploring the correlation between cost increases, purchasing power, and shifts in leisure expenditure to identify global trends and cross-country comparisons.\r - **Repository**: [gti-sos/SOS2526-24](https://github.com/gti-sos/SOS2526-24)",
  "homepage": "https://github.com/gti-sos/SOS2526-24#readme",
  "bugs": {
    "url": "https://github.com/gti-sos/SOS2526-24/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gti-sos/SOS2526-24.git"
  },
  "license": "ISC",
  "author": "SOS2526-24",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",

    "test-v1-IRG": "npx newman run tests/api/api-tests-Isaac.json -e tests/api/api-test-env-local.json",
    "test-v2-IRG": "npx newman run tests/api/api-tests-v2-Isaac.json -e tests/api/api-test-env-local.json",
    "test-Isaac-all": "npm run test-v1-IRG && npm run test-v2-IRG",
    "test-local-Isaac-versiones": "start-server-and-test start http://localhost:3000 test-Isaac-all",
    
    "test-v1-MJP": "npx newman run tests/api/api-tests-MJP.json -e tests/api/api-test-env-local-MJP.json",
    "test-v2-MJP": "npx newman run tests/api/api-tests-MJP-v2.json -e tests/api/api-test-env-local-MJP.json",
    "test-MJP-all": "npm run test-v1-MJP && npm run test-v2-MJP",
    "test-local-MJP-versiones": "start-server-and-test start http://localhost:3000 test-MJP-all",
    
    "test-international-construccion-costs": "npx newman run tests/api/api-tests-Isaac.json -e tests/api/api-test-env-local.json",
    "test-api-online-construccion-costs-render": "npx newman run tests/api/api-tests-Isaac.json -e tests/api/api-test-env-render.json",
    "test-local-Isaac": "start-server-and-test start http://localhost:3000 test-international-construccion-costs",
    "test-online-Isaac": "start-server-and-test start https://sos2526-24.onrender.com test-api-online-construccion-costs-render",
    
    "test-average-monthly-wages": "npx newman run tests/api/api-tests-MJP.json -e tests/api/api-test-env-local-MJP.json",
    "test-api-online-MJP-render": "npx newman run tests/api/api-tests-MJP.json -e tests/api/api-test-env-render-MJP.json",
    "test-local-MJP": "start-server-and-test start http://localhost:3000 test-average-monthly-wages",
    "test-online-MJP": "start-server-and-test start https://sos2526-24.onrender.com test-api-online-MJP-render",
    
    "test-recreation-culture-expenditure": "npx newman run tests/api/api-tests-v2-EBP.json -e tests/api/api-test-env-local-EBP.json",
    "test-api-online-EBP-render": "npx newman run tests/api/api-tests-v2-EBP.json -e tests/api/api-test-env-render-EBP.json",
    "test-local-EBP": "start-server-and-test start http://localhost:3000 test-recreation-culture-expenditure",
    "test-online-EBP": "start-server-and-test start https://sos2526-24.onrender.com test-api-online-EBP-render",

    "test-e2e-EBP": "playwright test tests/e2e/recreation-culture-expenditure.spec.js",
    "test-e2e-MJP": "playwright test tests/e2e/average-monthly-wages.spec.js",

    "start:e2e": "npm run build && npm run start",
    "build": "cd src/front && npm run build",
    "dev-front": "cd src/front &&  npm run dev -- --open",
    "test": "npm run test-local-Isaac-versiones && npm run test-local-MJP-versiones && npm run test-local-EBP"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "cool-ascii-faces": "^1.3.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "nedb": "^1.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@types/node": "^25.5.0",
    "start-server-and-test": "^2.1.5"
  }
}
