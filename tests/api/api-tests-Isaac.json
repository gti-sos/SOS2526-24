          "listen": "test",
          "script": {
            "exec": [
              "// 1. Comprobar que el servidor responde con un 200 OK\r",
              "pm.test(\"Estado de respuesta es 200 (Éxito)\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Comprobar que la respuesta es un array (fundamental para una colección)\r",
              "pm.test(\"La respuesta es un array\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "\r",
              "// Si hay datos, comprobar que los campos obligatorios existen en el primer elemento\r",
              "pm.test(\"Los elementos tienen la estructura correcta\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    if (jsonData.length > 0) {\r",
              "        pm.expect(jsonData[0]).to.have.property(\"country\");\r",
              "        pm.expect(jsonData[0]).to.have.property(\"year\");\r",
              "        pm.expect(jsonData[0]).to.have.property(\"city\");\r",
              "        pm.expect(jsonData[0]).to.have.property(\"cost_usd_per_m2\");\r",
              "    }\r",
              "});"
